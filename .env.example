# =============================================================================
# CaseLink — copy to .env.local for development.
# On Vercel: Project Settings → Environment Variables (Production + Preview).
# Never commit real secrets or .env.local.
# =============================================================================

# Required (Supabase → Project Settings → API). Safe to expose to the browser as NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site URL for auth redirects (signup, password reset). Prefer this over NEXT_PUBLIC_APP_URL.
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# Legacy alias for site URL (optional if NEXT_PUBLIC_SITE_URL is set).
# NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# Server-only — CSV import / admin scripts. Never NEXT_PUBLIC_* or client code.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only — OpenAI for plans, case assistant, step helpers. Omit to use rules-only plans + fallbacks.
# OPENAI_API_KEY=

# Optional model overrides (validated against src/lib/ai/model-allowlist.ts at startup).
# OPENAI_PLAN_MODEL=o3
# OPENAI_UI_MODEL=gpt-4.1-mini
# OPENAI_MODEL_OVERRIDE=

# Cost / abuse guardrails (optional).
# OPENAI_RATE_LIMIT_MAX_PER_MINUTE=30
# OPENAI_RATE_LIMIT_WINDOW_MS=60000
# Optional per-IP cap (same window as user limit; unset = IP limiting off).
# OPENAI_RATE_LIMIT_PER_IP_MAX=120
# OPENAI_MAX_INPUT_CHARS=120000
# OPENAI_MAX_OUTPUT_TOKENS=8192

# Verbose server logging only (never enables client-visible debug).
# OPENAI_DEBUG=1
# OPENAI_PAYLOAD_DEBUG=1
# PLAN_REGENERATE_DEBUG=1
# PLAN_REFINE_DEBUG=1
