# =============================================================================
# CaseLink — copy to .env.local for local development.
# Vercel: Project Settings → Environment Variables (set per environment).
# Never commit .env.local or real secrets.
# =============================================================================

# --- Public (embedded in the client bundle) ---
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical origin for auth redirects (sign-up, password reset). Prefer over NEXT_PUBLIC_APP_URL.
# NEXT_PUBLIC_SITE_URL=https://your-app.example

# Legacy alias for site URL (optional if NEXT_PUBLIC_SITE_URL is set).
# NEXT_PUBLIC_APP_URL=https://your-app.example

# --- Server-only (never NEXT_PUBLIC_* or browser code) ---
# CSV import and other privileged scripts only—not required for normal app runtime.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (optional). If unset, plan generation uses rules-based fallbacks where implemented.
# OPENAI_API_KEY=

# Optional model overrides (validated at startup; see src/lib/ai/model-allowlist.ts).
# OPENAI_PLAN_MODEL=o3
# OPENAI_UI_MODEL=gpt-4.1-mini
# OPENAI_MODEL_OVERRIDE=
# Additional task-specific overrides exist in src/lib/env.ts (e.g. OPENAI_PLAN_PHASE_MODEL).

# Cost and abuse guardrails (optional; defaults in getEnv()).
# OPENAI_RATE_LIMIT_MAX_PER_MINUTE=30
# OPENAI_RATE_LIMIT_WINDOW_MS=60000
# OPENAI_RATE_LIMIT_PER_IP_MAX=120
# OPENAI_MAX_INPUT_CHARS=120000
# OPENAI_MAX_OUTPUT_TOKENS=8192

# Server-only verbose logging (never toggles client-visible debug).
# OPENAI_DEBUG=1
# OPENAI_PAYLOAD_DEBUG=1
# PLAN_REGENERATE_DEBUG=1
# PLAN_REFINE_DEBUG=1
